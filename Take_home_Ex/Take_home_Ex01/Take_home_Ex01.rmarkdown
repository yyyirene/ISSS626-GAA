Importing the Singapore boundary data


```{r}
# 导入第1级行政边界
admin_level_1 <- st_read("data/rawdata/tha_admbnda_adm1_rtsd_20220121.shp")

# 导入第2级行政边界
admin_level_2 <- st_read("data/rawdata/tha_admbnda_adm2_rtsd_20220121.shp")

# 导入第3级行政边界
admin_level_3 <- st_read("data/rawdata/tha_admbnda_adm3_rtsd_20220121.shp")
```

```{r}
admin_level_1 <- st_transform(admin_level_1, 32647)
admin_level_2 <- st_transform(admin_level_2, 32647)
admin_level_3 <- st_transform(admin_level_3, 32647)
```

```{r}

# 筛选第一级行政边界
admin_level_1_filtered <- admin_level_1 %>%
  filter(ADM1_EN %in% selected_provinces)

# 筛选第二级行政边界
admin_level_2_filtered <- admin_level_2 %>%
  filter(ADM1_EN %in% selected_provinces)

# 筛选第三级行政边界
admin_level_3_filtered <- admin_level_3 %>%
  filter(ADM1_EN %in% selected_provinces)
```

```{r}
write_rds(admin_level_1_filtered,"data/rds/admin_level_1_filtered.rds")
write_rds(admin_level_2_filtered,"data/rds/admin_level_2_filtered.rds")
write_rds(admin_level_3_filtered,"data/rds/admin_level_3_filtered.rds")
```

```{r}
admin_level_1_filtered <- read_rds("data/rds/admin_level_1_filtered.rds")
admin_level_2_filtered <- read_rds("data/rds/admin_level_2_filtered.rds")
admin_level_3_filtered <- read_rds("data/rds/admin_level_3_filtered.rds")
```

```{r}
admin_level_2_filtered_owin <- as.owin(admin_level_2_filtered)
admin_level_2_filtered_owin
```

```{r}
class(admin_level_2_filtered_owin)
```

```{r}
tm_shape(admin_level_2_filtered)+
  tm_polygons() +
tm_shape(acci) +
  tm_dots()
```

```{r}
tm_shape(admin_level_2_filtered)+
  tm_polygons() +
tm_shape(acci) +
  tm_dots(size = 0.1) +
tm_facets(by="Month_fac", 
            free.coords=FALSE, 
            drop.units = TRUE)
```

```{r}
acci_month <- acci %>% 
  select(Month_num)
```

```{r}
acci_month_ppp <- as.ppp(acci_month)
acci_month_ppp
```

```{r}
summary(acci_month_ppp)
```

```{r}
any(duplicated(acci_month_ppp))
```

```{r}
