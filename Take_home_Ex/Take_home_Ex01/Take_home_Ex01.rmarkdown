ggplot() +
  geom_sf(data = admin_level_1_filtered, aes(fill = ifelse(ADM1_EN == "Bangkok", "Bangkok", "Other")), color = "black") +  # 设置不同的填充颜色
  geom_sf_text(data = admin_level_1_filtered, aes(label = ADM1_EN), size = 3, color = "black") +  # 添加省份名称标签
  scale_fill_manual(values = c("Bangkok" = "yellow", "Other" = "grey")) +  # 设置曼谷为黄色，其他为灰色
  theme_minimal() +
  labs(title = "Bangkok Metropolitan Region", fill = "Region")  # 添加图例标题

