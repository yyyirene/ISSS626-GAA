6.9.1 Creating ppp object


```{r}
acci_yday_ppp <- acci %>% 
  select(dayofyear) %>%
  as.ppp()
```

```{r}
acci_yday_owin <- acci_yday_ppp[admin_level_2_filtered_owin]
summary(acci_yday_owin)
```

```{r}
# 假设 fire_month_owin 是点模式数据，月份信息存储在 marks 中
# 创建颜色向量，为每个月分配不同的颜色
month_colors <- colorRampPalette(c("blue", "green", "yellow", "red"))(12)

# 绘制带有颜色区分的图
plot(acci_month_owin, cols = month_colors[as.numeric(marks(acci_month_owin))],
     main = "Accidents by Month", legend = TRUE)

```

```{r}
acci_wday_owin <- acci_wday_ppp[admin_level_2_filtered_owin]
summary(acci_wday_owin)
```

```{r}
# 假设 fire_month_owin 是点模式数据，月份信息存储在 marks 中
# 创建颜色向量，为每个月分配不同的颜色
week_colors <- colorRampPalette(c("blue", "green", "yellow", "red"))(12)

# 绘制带有颜色区分的图
plot(acci_week_owin, cols = week_colors[as.numeric(marks(acci_week_owin))],
     main = "Accidents by Month", legend = TRUE)

```

```{r}
# 使用边界数据（如Bangkok Metropolitan Region）与道路数据进行空间连接
road_bmr <- st_join(road, admin_level_1_filtered)

# 只保留与目标区域（如BMR）相交的道路
road_bmr <- road_bmr[!is.na(road_bmr$ADM1_EN), ]  # ADM1_EN是省份的名称列

# 绘制结果
plot(st_geometry(road_bmr), col = "blue", main = "BMR")

```

